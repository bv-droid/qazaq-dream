# ── Qazaq Dream · настройки для Apache (ps.kz shared hosting) ──

AddDefaultCharset UTF-8
DirectoryIndex index.html

# Кадры фильма не меняются — держим их в кэше браузера год.
# Версия монтажа передаётся через ?v= в адресе, поэтому при переклейке
# кэш сбрасывается сам, без правки этих настроек.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType text/html               "access plus 5 minutes"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# Сжатие текста. JPEG не сжимаем — он уже сжат, толку нет.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# Без листинга каталогов
Options -Indexes
